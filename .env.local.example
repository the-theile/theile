# ── AI provider (pick ONE free option, or pay for xAI) ──────────────
# Dictabird auto-uses the first key it finds, preferring free providers:
#   1) GROQ_API_KEY   (free)  https://console.groq.com/keys
#   2) GEMINI_API_KEY (free)  https://aistudio.google.com/apikey
#   3) XAI_API_KEY    (paid)  https://console.x.ai
#
# Force a provider: AI_PROVIDER=groq | gemini | xai

GROQ_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=

# Optional model overrides
# AI_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash
# XAI_MODEL=grok-4.5
